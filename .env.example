# Copy to ".env" and adjust for your network.

# Shared password for the web control panel. Leave empty to DISABLE auth
# (only do this on a fully trusted network).
APP_PASSWORD=changeme

# Stable secret used to sign session cookies. Generate one with:
#   openssl rand -hex 32
# Optional: if left empty, a persistent secret is generated automatically and
# stored in the data volume (data/session.secret), so logins survive restarts.
# Set this explicitly only if you want to control/rotate the secret yourself.
SESSION_SECRET=

# How long a login stays valid. Default is ~10 years ("stay signed in until you
# log out"). Browsers may still cap the cookie lifetime (Chrome ~400 days).
SESSION_TTL_DAYS=3650

# REQUIRED for WebRTC across the network: the Docker host's LAN IP plus the
# published WebRTC port. Browsers use this to establish the video connection.
# Find your host IP (e.g. 192.168.1.10) and set:
GO2RTC_WEBRTC_CANDIDATE=192.168.1.10:8555

# Port the web UI is published on (host side).
APP_PORT=8080
