{
  "name": "@rtsp-webui/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Electron wrapper that runs the RTSP WebUI server + go2rtc locally.",
  "author": "RTSP WebUI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "predist": "node scripts/prepare-resources.mjs",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "42.3.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "dev.rtspwebui.desktop",
    "productName": "RTSP WebUI",
    "files": [
      "main.js"
    ],
    "extraResources": [
      {
        "from": "../bin",
        "to": "bin"
      },
      {
        "from": "../web/dist",
        "to": "web/dist"
      },
      {
        "from": "staging/server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "staging/server/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}