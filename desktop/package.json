{
  "name": "@rtsp-webui/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Electron wrapper that runs the RTSP WebUI server + go2rtc locally.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "dev.rtspwebui.desktop",
    "productName": "RTSP WebUI",
    "files": [
      "main.js",
      "../server/**",
      "../web/dist/**"
    ],
    "extraResources": [
      { "from": "../bin", "to": "bin" }
    ]
  }
}
